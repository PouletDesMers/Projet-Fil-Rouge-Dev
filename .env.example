# Copiez ce fichier en .env et remplissez vos vraies valeurs

# === Base de données ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=mydb
DB_SSLMODE=disable

# === URLs des services ===
API_URL=http://localhost:8080
API_PORT=8080
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# === CORS (origines autorisées, séparées par des virgules) ===
ALLOWED_ORIGINS=http://localhost:3000,https://cyna.fr,https://app.cyna.fr

# === Clés API ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
RESEND_API_KEY=resend_...
RESEND_FROM=CYNA <noreply@votredomaine.fr>
API_KEY=your_api_secret_key
API_SECRET=your_api_secret

# === Backup ===
RESTIC_PASSWORD=your_strong_restic_password
RESTIC_REPOSITORY=/backups/restic-repo

# === SMTP ===
SMTP_FROM=
SMTP_PASSWORD=

# === Expo (app mobile) ===
EXPO_PUBLIC_API_URL=http://localhost:8080/api
